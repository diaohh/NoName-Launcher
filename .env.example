# Microsoft Azure App Configuration
# Register your app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=your-azure-client-id-here

# Launcher Configuration
LAUNCHER_NAME=NoNameLauncher
LAUNCHER_VERSION=1.0.0

# Distribution URL (JSON file with server configuration)
DISTRIBUTION_URL=https://your-server.com/distribution.json

# Development Mode
NODE_ENV=development
